# CaseCraft Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# REQUIRED: OpenAI Configuration
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# Make sure the key has "model.request" scope enabled
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# REQUIRED: Pinecone Configuration (for document search/RAG)
# =============================================================================
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=legal-docs

# =============================================================================
# OPTIONAL: Voice Features (Retell AI)
# =============================================================================
# Get your API key from: https://dashboard.retellai.com/
# Only required if using voice call features
RETELL_API_KEY=your-retell-api-key-here
RETELL_WS_URL=wss://your-domain.com/llm-websocket
RETELL_WS_PORT=8081

# =============================================================================
# OPTIONAL: Premium Text-to-Speech (ElevenLabs)
# =============================================================================
# Get your API key from: https://elevenlabs.io/
# Falls back to OpenAI TTS if not configured
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# =============================================================================
# OPTIONAL: Google OAuth
# =============================================================================
# Configure in Supabase Dashboard > Authentication > Providers > Google
# These are set in Supabase, not in this file
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
